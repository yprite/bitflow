# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# 텔레그램 웹훅 시크릿 (선택. 웹훅 설정 시 secret_token으로 사용)
TELEGRAM_WEBHOOK_SECRET=

# Vercel KV (Vercel 대시보드에서 KV 스토어 생성 후 자동 설정됨)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase (김프 히스토리 저장 시 필요)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 관리자 대시보드 인증키 (/admin 페이지 로그인에 사용)
ADMIN_SECRET=

# 스케줄 호출 인증 시크릿 (외부 스케줄러를 쓸 때만 필요)
CRON_SECRET=

# Google AdSense 퍼블리셔 ID (예: 8082243736281483 또는 pub-8082243736281483)
GOOGLE_ADSENSE_PUBLISHER_ID=
